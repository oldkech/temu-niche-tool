# ─── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Server ───────────────────────────────────────────────────
PORT=3000

# ─── WordPress: couponhubusa.com ──────────────────────────────
# Use a WordPress Application Password (Users → Profile → Application Passwords)
WP_COUPONHUBUSA_URL=https://couponhubusa.com
WP_COUPONHUBUSA_USER=your_wp_username
WP_COUPONHUBUSA_PASSWORD=your_wp_application_password

# ─── WordPress: couponcodesglitch.com ────────────────────────
WP_COUPONCODESGLITCH_URL=https://couponcodesglitch.com
WP_COUPONCODESGLITCH_USER=your_wp_username
WP_COUPONCODESGLITCH_PASSWORD=your_wp_application_password
